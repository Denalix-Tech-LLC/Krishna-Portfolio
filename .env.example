# Copy this file to .env.local and set your own values.

# Protects the /admin content editor. Basic protection — fine for a personal
# portfolio, not for anything sensitive.
ADMIN_PASSWORD=change-me

# ---- Optional: make the admin Save button work on read-only hosts (Vercel) ----
# When the server can't write files, Save commits content/site-content.json to
# your GitHub repo instead, and the host redeploys automatically.
#   GITHUB_TOKEN  — fine-grained personal access token with "Contents: Read and
#                   write" permission on ONLY this repository
#   GITHUB_REPO   — "owner/repo", e.g. "krishna/krishna-portfolio"
#   GITHUB_BRANCH — optional, defaults to "main"
# GITHUB_TOKEN=
# GITHUB_REPO=
# GITHUB_BRANCH=main
